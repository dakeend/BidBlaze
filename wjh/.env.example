# Backend: copy into server-go/.env when the backend starts reading env files.
APP_ENV=dev
APP_PORT=8080
APP_TIMEZONE=Asia/Shanghai

MYSQL_DSN=root:auction_root@tcp(127.0.0.1:3306)/auction?parseTime=true&loc=UTC&charset=utf8mb4
MYSQL_MAX_OPEN=50
MYSQL_MAX_IDLE=10

REDIS_ADDR=127.0.0.1:6379
REDIS_DB=0

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_PREFIX=http://localhost:8080/static

MOCK_TOKEN_SECRET=auction-dev-secret-2026
MOCK_TOKEN_TTL_HOURS=720

OUTBOX_POLL_INTERVAL_MS=200
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRIES=10
OUTBOX_RETRY_BASE_MS=200
OUTBOX_RETRY_MAX_MS=5000
OUTBOX_PUBLISH_TIMEOUT_MS=1000
OUTBOX_REDIS_PREFIX=auction:events:

LIFECYCLE_TICK_MS=500
LIFECYCLE_BATCH_SIZE=100

RATE_LIMIT_BID_PER_SEC=3
RATE_LIMIT_STATUS_PER_SEC=2

LOG_LEVEL=info
LOG_FORMAT=json

# Frontend: create per-app .env files when needed.
VITE_API_BASE=http://localhost:8080
VITE_WS_BASE=ws://localhost:8080
